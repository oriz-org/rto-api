---
import Layout from '../layouts/Layout.astro';

const sample = {
  code: 'MH-12',
  state_code: 'MH',
  state: 'Maharashtra',
  office: 'Pune',
  district: 'Pune',
  notes: '',
};
---
<Layout path="/">
  <section class="mx-auto max-w-5xl px-6 pt-20 pb-12">
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
      Indian RTO Codes
      <span class="text-saffron-600 dark:text-saffron-400">API</span>
    </h1>
    <p class="mt-5 max-w-2xl text-lg text-zinc-600 dark:text-zinc-400">
      Free static API for all <strong class="font-semibold text-zinc-900 dark:text-zinc-100">1299</strong> Indian Regional Transport Office codes.
      No auth, no rate limit, no cost. Just JSON.
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/docs" class="rounded-md bg-saffron-600 px-4 py-2 text-sm font-medium text-white shadow-sm transition-colors hover:bg-saffron-700">Read the docs</a>
      <a href="/explorer" class="rounded-md border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-700 transition-colors hover:border-saffron-500 hover:text-saffron-700 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-saffron-500 dark:hover:text-saffron-400">Try the explorer</a>
      <a href="https://github.com/oriz-org/rto-api" target="_blank" rel="noopener noreferrer" class="rounded-md border border-zinc-300 px-4 py-2 text-sm font-medium text-zinc-700 transition-colors hover:border-zinc-500 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500">Source on GitHub</a>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Try it</h2>
    <div class="mt-4 grid gap-4 lg:grid-cols-2">
      <div>
        <p class="mb-2 text-sm text-zinc-600 dark:text-zinc-400">Request:</p>
        <pre class="overflow-x-auto rounded-md border border-zinc-200 bg-zinc-50 p-4 text-sm dark:border-zinc-800 dark:bg-zinc-900"><code class="font-mono text-zinc-800 dark:text-zinc-200">curl https://rto.oriz.in/codes/MH-12.json</code></pre>
      </div>
      <div>
        <p class="mb-2 text-sm text-zinc-600 dark:text-zinc-400">Response:</p>
        <pre class="overflow-x-auto rounded-md border border-zinc-200 bg-zinc-50 p-4 text-sm dark:border-zinc-800 dark:bg-zinc-900"><code class="font-mono text-zinc-800 dark:text-zinc-200">{JSON.stringify(sample, null, 2)}</code></pre>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">How to use</h2>
    <div class="mt-4 grid gap-6 md:grid-cols-2">
      <div class="rounded-lg border border-zinc-200 p-5 dark:border-zinc-800">
        <h3 class="font-mono text-sm font-semibold text-saffron-700 dark:text-saffron-400">via rto.oriz.in</h3>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">Cloudflare Pages, custom domain, free TLS. Recommended for browser apps.</p>
        <pre class="mt-3 overflow-x-auto rounded bg-zinc-50 p-3 text-xs dark:bg-zinc-900"><code class="font-mono">https://rto.oriz.in/codes/MH-12.json</code></pre>
      </div>
      <div class="rounded-lg border border-zinc-200 p-5 dark:border-zinc-800">
        <h3 class="font-mono text-sm font-semibold text-saffron-700 dark:text-saffron-400">via jsDelivr</h3>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">Pinned to a git ref. Recommended for production code that wants reproducibility.</p>
        <pre class="mt-3 overflow-x-auto rounded bg-zinc-50 p-3 text-xs dark:bg-zinc-900"><code class="font-mono">https://cdn.jsdelivr.net/gh/oriz-org/rto-api@main/codes/MH-12.json</code></pre>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Stats</h2>
    <dl class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-5">
      <div class="rounded-lg border border-zinc-200 p-4 dark:border-zinc-800">
        <dt class="text-xs text-zinc-500 dark:text-zinc-500">Codes</dt>
        <dd class="mt-1 font-mono text-2xl font-semibold">1299</dd>
      </div>
      <div class="rounded-lg border border-zinc-200 p-4 dark:border-zinc-800">
        <dt class="text-xs text-zinc-500 dark:text-zinc-500">States &amp; UTs</dt>
        <dd class="mt-1 font-mono text-2xl font-semibold">35</dd>
      </div>
      <div class="rounded-lg border border-zinc-200 p-4 dark:border-zinc-800">
        <dt class="text-xs text-zinc-500 dark:text-zinc-500">Data license</dt>
        <dd class="mt-1 font-mono text-lg font-semibold">CC BY-SA</dd>
      </div>
      <div class="rounded-lg border border-zinc-200 p-4 dark:border-zinc-800">
        <dt class="text-xs text-zinc-500 dark:text-zinc-500">Code license</dt>
        <dd class="mt-1 font-mono text-lg font-semibold">MIT</dd>
      </div>
      <div class="rounded-lg border border-zinc-200 p-4 dark:border-zinc-800">
        <dt class="text-xs text-zinc-500 dark:text-zinc-500">Cost</dt>
        <dd class="mt-1 font-mono text-2xl font-semibold">&#8377;0/mo</dd>
      </div>
    </dl>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-12">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Why use this</h2>
    <ul class="mt-4 space-y-2 text-zinc-700 dark:text-zinc-300">
      <li class="flex gap-3"><span class="text-saffron-600 dark:text-saffron-400">&middot;</span> Static JSON files &mdash; no API key, no rate limit, no quota.</li>
      <li class="flex gap-3"><span class="text-saffron-600 dark:text-saffron-400">&middot;</span> Served from Cloudflare Pages and jsDelivr edge caches.</li>
      <li class="flex gap-3"><span class="text-saffron-600 dark:text-saffron-400">&middot;</span> Open data &mdash; pinned to a git ref for reproducible builds.</li>
      <li class="flex gap-3"><span class="text-saffron-600 dark:text-saffron-400">&middot;</span> Single GitHub source of truth &mdash; fork it, audit it, send a PR.</li>
    </ul>
    <div class="mt-8 flex flex-wrap gap-4 text-sm">
      <a href="/docs" class="text-saffron-700 underline decoration-saffron-500/40 underline-offset-4 hover:decoration-saffron-500 dark:text-saffron-400">API reference &rarr;</a>
      <a href="https://github.com/oriz-org/rto-api/blob/main/CONTRIBUTING.md" class="text-saffron-700 underline decoration-saffron-500/40 underline-offset-4 hover:decoration-saffron-500 dark:text-saffron-400" target="_blank" rel="noopener noreferrer">Contribute a fix &rarr;</a>
    </div>
  </section>
</Layout>
