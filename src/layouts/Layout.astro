---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = 'Indian RTO Codes API',
  description = 'Free static API for all 1299 Indian Regional Transport Office codes. No auth, no rate limit, no cost.',
  path = '/',
} = Astro.props;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/docs', label: 'Docs' },
  { href: '/explorer', label: 'Explorer' },
  { href: 'https://github.com/oriz-org/rto-api', label: 'GitHub', external: true },
];
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#f5841a" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1a1a" media="(prefers-color-scheme: dark)" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://rto.oriz.in${path}`} />
  </head>
  <body class="min-h-screen bg-white text-zinc-900 antialiased dark:bg-zinc-950 dark:text-zinc-100">
    <header class="border-b border-zinc-200 dark:border-zinc-800">
      <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-baseline gap-2 font-mono text-sm font-semibold tracking-tight">
          <span class="text-saffron-600 dark:text-saffron-400">rto</span>
          <span class="text-zinc-400 dark:text-zinc-600">.oriz.in</span>
        </a>
        <ul class="flex items-center gap-6 text-sm">
          {nav.slice(1).map((item) => (
            <li>
              <a
                href={item.href}
                class={`text-zinc-600 transition-colors hover:text-saffron-600 dark:text-zinc-400 dark:hover:text-saffron-400 ${
                  path === item.href ? 'text-zinc-900 dark:text-zinc-100' : ''
                }`}
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noopener noreferrer' : undefined}
              >{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mt-24 border-t border-zinc-200 dark:border-zinc-800">
      <div class="mx-auto max-w-5xl px-6 py-10 text-sm text-zinc-500 dark:text-zinc-500">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <p>
            Built by <a href="https://oriz.in" class="underline decoration-saffron-500 underline-offset-4 hover:text-saffron-600 dark:hover:text-saffron-400">oriz.in</a>
            &middot; Code MIT &middot; Data CC BY-SA 4.0 (Wikipedia)
          </p>
          <div class="flex items-center gap-4">
            <a href="https://github.com/oriz-org/rto-api" class="hover:text-saffron-600 dark:hover:text-saffron-400" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href="https://www.buymeacoffee.com/oriz" class="hover:text-saffron-600 dark:hover:text-saffron-400" target="_blank" rel="noopener noreferrer">Buy me a coffee</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
